# Copy to styx.yaml. `name` is the node's identity AND its SSH login (the PIPASS
# account). Mesh overlay IPs assign automatically. With bootstrap: true, the local
# node's public_ipv4/public_ipv6 are auto-detected (curl -4/-6 ifconfig.me); remote
# peers are found by resolving each node's `hostname` (its DuckDNS name) — no SSH or
# port-forward needed just to discover one. Colocated peers (same WAN) are found by a
# LAN scan and reached over their lan_ip. Port 22 is admin SSH only — styxctl uses 47810.
#
# PREREQUISITE: each remote node runs a DuckDNS updater keeping its `hostname` current.
# styxctl only RESOLVES these names, so it needs no DuckDNS token.
# NOTE: do NOT set cluster.dns_suffix here — node names (kraken, pegasus) are NOT unique
# DuckDNS subdomains, so deriving {name}.duckdns.org would resolve to strangers' boxes.
# Always map the real, unique subdomain explicitly via `hostname:`.

cluster:
  name: styx
  leader: lan-elected
  bootstrap: true

nodes:
  # IN CI this nodes list is AUTO-GENERATED from the live GitHub runner labels
  # (.github/scripts/generate_styx_config.py) — the runner labels are the single source of
  # truth, so you never hand-edit roles here for the test. The list below is only the
  # reference for real (non-CI) deployments. Roles mirror each Pi's runner labels: exactly
  # ONE init-server, then servers, then agents. Each node's hostname is its unique DuckDNS
  # name (atlas borrows pegasus's — there is no piatlas).
  - name: pegasus
    role: init-server
    hostname: pipegasus.duckdns.org
  - name: hydra
    role: server
    hostname: pihydra.duckdns.org
  - name: kraken
    role: agent
    hostname: pikraken.duckdns.org
  - name: atlas
    role: agent
    hostname: pipegasus.duckdns.org   # no piatlas; colocated with pegasus, borrows its
    # name (shared WAN IP). The LAN scan distinguishes atlas by its own lan_ip.

  # thor — OFFLINE right now. It's the remote-site node and is init-server+server capable,
  # but pegasus already holds the single init-server slot, so thor joins as a server.
  # Adding an unreachable node would fail stage-2 connectivity, so leave it commented
  # until thor is back online, then uncomment:
  # - name: thor
  #   role: server
  #   hostname: pithor.duckdns.org

# pistyx.duckdns.org is a floating cluster name (not a node) — reserved for pointing at
# the current leader/entrypoint so agents always have one stable endpoint to bootstrap to.

# MVP3 — publish the floating name from inside the cluster. `styxctl deploy dns apply`
# (run on the init-server) renders a tiny updater Deployment pinned to the init-server
# node, so its egress IP is the cluster WAN. The DuckDNS token is NOT stored here: it is
# read from $DUCKDNS_TOKEN at apply time (a repository secret in CI, like PIPASS) and
# stored only as a k8s Secret. Preview with `styxctl deploy dns plan`.
dns:
  provider: duckdns
  domains: [pistyx]        # floating cluster name(s) to keep current
  interval_seconds: 300
