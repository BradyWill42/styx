# Copy to styx.yaml. SSH username defaults to each node name (hostname).
# Mesh overlay IPs assign automatically. With bootstrap: true, public_ipv4/public_ipv6
# and lan_ip are auto-detected (curl -4/-6 on ifconfig.me; SSH to peers on port 22).
# Styx cluster SSH uses gateway.ssh_port (47810); port 22 stays for admin/runner access.

cluster:
  name: styx
  leader: lan-elected
  bootstrap: true

nodes:
  - name: pegasus
    role: init-server
  - name: atlas
    role: agent
  - name: thor
    role: server
