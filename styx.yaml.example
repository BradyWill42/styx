cluster:
  name: styx
  ssh_user: ubuntu
  lan_interface: eth0

nodes:
  # Replace hostnames with your DuckDNS subdomains (or other stable DNS names).
  # Mesh overlay IPs (10.0.0.x / fd00:cafe::x) are assigned automatically from node order.
  # LAN IPs and public WAN IPs are auto-detected at install time.
  - name: node-init
    hostname: styx-lab-init.duckdns.org
    role: init-server
  - name: node-server
    hostname: styx-lab-server.duckdns.org
    role: server
  - name: node-agent
    hostname: styx-lab-agent.duckdns.org
    role: agent

dns:
  token_env: DUCKDNS_TOKEN
