# Copy to styx.yaml. `name` is the node's identity AND its SSH login (the PIPASS
# account). Mesh overlay IPs assign automatically. The local node's public_ipv4/public_ipv6
# are auto-detected (curl -4/-6 ifconfig.me); remote peers are found by resolving each node's
# `hostname` (its DuckDNS name) — no SSH or port-forward needed just to discover one. Colocated
# peers (same WAN/public IP) are found by a LAN scan and reached over their lan_ip. In Styx, a
# site is a place with a distinct public IP; nodes sharing one public IP are one site. Each site
# LAN-elects its leader (port-forward face + DuckDNS publisher + styx uplink). Port 22 is admin SSH only —
# styxctl uses 47810.
#
# PREREQUISITE: each remote node runs a DuckDNS updater keeping its `hostname` current.
# styxctl only RESOLVES these names, so it needs no DuckDNS token.
# NOTE: node names (kraken, pegasus) are NOT unique DuckDNS subdomains, so always map the real,
# unique subdomain explicitly via `hostname:` — never derive {name}.duckdns.org.

cluster:
  name: styx

nodes:
  # IN CI this nodes list is AUTO-GENERATED from the live GitHub runner labels
  # (.github/scripts/generate_styx_config.py) — the runner labels are the single source of
  # truth. `role` is NOT listed here: it is injected from each runner's role label (exactly
  # ONE init-server, then servers, then agents). For a MANUAL (non-CI) deploy, add
  # `role: init-server|server|agent` to each node yourself. Each node's hostname is its unique
  # DuckDNS name (atlas borrows pegasus's — there is no piatlas).
  - name: pegasus
    hostname: pipegasus.duckdns.org
  - name: hydra
    hostname: pihydra.duckdns.org
  - name: kraken
    hostname: pikraken.duckdns.org
  - name: atlas
    hostname: pipegasus.duckdns.org   # no piatlas; colocated with pegasus, borrows its
    # name (shared WAN IP). The LAN scan distinguishes atlas by its own lan_ip.

  # thor — OFFLINE right now. It's the remote-site node; uncomment when it's back online:
  # - name: thor
  #   hostname: pithor.duckdns.org

# `styxctl mesh up` renders the backbone `Styx` config plus one `StyxSite<N>` config per
# physical WAN site on every Pi. `Styx` is `10.0.0.0/24`; site *N* owns
# `10.0.N.0/24`. Pi identities keep their Styx suffix in every site, generated
# clients start at `.64`, and pistyx uses service suffix `.254`.

# pistyx.duckdns.org is a floating cluster name (not a node) — the single movable EGRESS endpoint
# (see the `egress:`/`pistyx:` blocks below). The per-site endpoints are the river banks; pistyx
# is the river. Auto-repointing to the "quickest site" is still deferred; the move is manual for now.

# MVP3 — per-site DuckDNS publishers. `styxctl deploy dns apply` (run on the init-server)
# renders ONE updater Deployment per site, pinned to that site's leader, that keeps the
# site's DuckDNS names (each node's `hostname`, e.g. pipegasus/pihydra) pointed at the
# site's public IPv4+IPv6 (the leader's WAN). Names are derived from node hostnames — not
# listed here. DuckDNS is the only provider. The DuckDNS token is NOT stored here: it's read
# from $DUCKDNS_TOKEN at apply time (a repository secret in CI, like PIPASS) into a k8s Secret.
dns:
  interval_seconds: 300

# pistyx — the floating client entry that bounces clients to the FASTEST site (local breakout).
#
# Each site is a self-contained PoP: its leader runs the pistyx interface (StyxEgress, 47801/udp)
# bound to a SHARED pistyx identity (same WG key on every leader) and LOCAL-NATs client traffic out
# its OWN internet. Styx never carries client traffic — each site egresses locally.
#
# ENTRY: `styxctl client config <name>` emits a roadwarrior config that dials `pistyx.duckdns.org`
# (the floating name) and full-tunnels to it; `--site <node>` pins one site instead of auto-fastest.
# A client peers the SHARED pistyx key, so when the name repoints it reconnects with zero reconfig.
#
# FASTEST-SITE (Phase 2, needs >=2 real sites): a client lands on a site → that site RTT-probes the
# client's IP from every site over the backbone → repoints pistyx.duckdns.org to the lowest-latency
# site → client reconnects there. The stable pistyx key is pre-staged on every node's LOCAL disk at
# `mesh up`. Inspect with `styxctl mesh pistyx show`.
egress:
  interface: StyxEgress
  port: 47801                 # within the forwarded 47800-47850 range; must differ from wireguard.port
  mtu: 1420                   # client full-tunnel encapsulation overhead; lower for PPPoE/native-v6
  hostname: pistyx.duckdns.org

# The current pistyx holder + the SHARED pistyx PUBLIC key (clients peer it; the private key is NOT
# stored here — it's pre-staged on each node's local disk). Optional; holder defaults to the init-server.
# pistyx:
#   current_host: pegasus
#   public_key: "<shared pistyx WG public key — `styxctl mesh pistyx pubkey-local` prints it>"

# clients: roadwarriors registered as peers on every leader's pistyx PoP (so a repoint reconnects
# them transparently). The third octet follows the site they enter, while the final octet is the
# stable device identity; 10.0.1.7 and 10.0.2.7 are the same client seen from two site scopes.
# Add issued clients here to persist the suffix.
# clients:
#   - name: brady-laptop
#     public_key: "<client WG public key>"
#     host_suffix: 2

# Cluster DNS (all pod-based). `styxctl deploy resolver apply` deploys a node-local CoreDNS cache
# (DaemonSet on 127.0.0.1:53) plus a privileged enforcer DaemonSet that points each node's
# /etc/resolv.conf at it and `chattr +i` locks it. `styxctl deploy resolver delete` uninstalls
# cleanly — each node's enforcer restores its original resolv.conf on teardown (TERM trap).
# resolver:
#   upstreams: [1.1.1.1, 9.9.9.9]   # where the node-local cache forwards queries
#   force: true                      # false = deploy the cache but DON'T lock /etc/resolv.conf
